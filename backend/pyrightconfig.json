{
  "venvPath": ".",
  "venv": "venv",
  "pythonVersion": "3.11",
  "pythonPath": "./venv/Scripts/python.exe",
  "include": ["."],
  "exclude": ["__pycache__", "venv"],
  "extraPaths": [".", "./venv/Lib/site-packages"],
  "typeCheckingMode": "basic",
  "reportMissingModuleSource": "none",
  "reportMissingImports": "none"
}
